# ══════════════════════════════════════════════════════════════════
#  RSU Health Platform — Production .env (Plesk)
#  คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าทุกช่องที่มี YOUR_ หรือ CHANGE_ME
# ══════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────
APP_NAME="RSU Medical Hub"
APP_ENV=production
APP_KEY=                             # php artisan key:generate
APP_DEBUG=false
APP_URL=https://medical.rsu.ac.th   # เปลี่ยนเป็น domain จริง

APP_LOCALE=th
APP_FALLBACK_LOCALE=th
APP_FAKER_LOCALE=th_TH
APP_TIMEZONE=Asia/Bangkok

# ── Logging ───────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error                      # production: error เท่านั้น

# ── Database (MySQL จาก Plesk) ────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost                    # หรือ 127.0.0.1
DB_PORT=3306
DB_DATABASE=YOUR_DB_NAME             # ชื่อ DB ใน Plesk
DB_USERNAME=YOUR_DB_USER             # ชื่อ User ใน Plesk
DB_PASSWORD=YOUR_DB_PASSWORD         # Password ที่ตั้งใน Plesk

# ── Cache / Session / Queue ───────────────────────────────────────
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true           # production ต้องเป็น true (HTTPS)
QUEUE_CONNECTION=database

# ── Mail (แก้ตาม SMTP ของ RSU หรือ Mailtrap/Mailgun) ─────────────
MAIL_MAILER=smtp
MAIL_HOST=YOUR_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=YOUR_SMTP_USER
MAIL_PASSWORD=YOUR_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@rsu.ac.th
MAIL_FROM_NAME="RSU Medical Hub"

# ── LINE OAuth ────────────────────────────────────────────────────
LINE_CLIENT_ID=YOUR_LINE_CLIENT_ID
LINE_CLIENT_SECRET=YOUR_LINE_CLIENT_SECRET
LINE_REDIRECT_URI="${APP_URL}/auth/line/callback"

# LINE Messaging API (สำหรับส่ง push notification)
LINE_CHANNEL_ACCESS_TOKEN=YOUR_LINE_CHANNEL_ACCESS_TOKEN
LINE_CHANNEL_SECRET=YOUR_LINE_CHANNEL_SECRET

# ── Google OAuth (Admin login) ────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ── Sentry (Error Tracking) ───────────────────────────────────────
SENTRY_LARAVEL_DSN=YOUR_SENTRY_DSN
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Filesystem ───────────────────────────────────────────────────
FILESYSTEM_DISK=local

# ── Vite (frontend) ───────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"

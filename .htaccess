# e-campaignv2/.htaccess

Options -Indexes

# Enable Rewrite
RewriteEngine On

# Suppress favicon.ico 404 — return empty 204 No Content
RewriteRule ^favicon\.ico$ - [R=204,L]

# DirectoryIndex
DirectoryIndex index.php index.html

# ─── Custom Error Pages ───────────────────────────────────────
ErrorDocument 400 /e-campaignv2/errors/404.php
ErrorDocument 403 /e-campaignv2/errors/403.php
ErrorDocument 404 /e-campaignv2/errors/404.php
ErrorDocument 500 /e-campaignv2/errors/500.php
ErrorDocument 502 /e-campaignv2/errors/500.php
ErrorDocument 503 /e-campaignv2/errors/503.php
ErrorDocument 504 /e-campaignv2/errors/503.php
